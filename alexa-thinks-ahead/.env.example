# ============================================================
# Alexa Thinks Ahead - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control (it contains secrets).
# ============================================================

# ----- AWS Credentials -----
# Your AWS access key and secret (from IAM console)
AWS_ACCESS_KEY_ID=your-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here
AWS_DEFAULT_REGION=ap-south-1

# ----- Amazon Bedrock -----
# Model ID for Claude Sonnet (no change needed unless using a different version)
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_REGION=ap-south-1

# ----- SAM Deployment -----
# Stack name for CloudFormation
SAM_STACK_NAME=alexa-thinks-ahead
# Deployment stage (dev, staging, or prod)
STAGE=dev
# S3 bucket for SAM deployment artifacts (SAM creates one if you use --guided)
SAM_S3_BUCKET=

# ----- DynamoDB Table Names (auto-created by SAM, but listed for local dev) -----
DEVICE_STATE_TABLE=alexa-thinks-ahead-device-states-dev
CONTEXT_SNAPSHOT_TABLE=alexa-thinks-ahead-context-snapshots-dev
TRUST_SCORE_TABLE=alexa-thinks-ahead-trust-scores-dev
PREFERENCE_TABLE=alexa-thinks-ahead-preferences-dev

# ----- EventBridge -----
EVENT_BUS_NAME=alexa-thinks-ahead-events-dev

# ----- Alexa Skill -----
# Your Alexa Skill ID (from Alexa Developer Console after creating the skill)
ALEXA_SKILL_ID=amzn1.ask.skill.your-skill-id-here

# ----- API Gateway -----
# After first deploy, paste the API URL from stack outputs here
API_BASE_URL=

# ----- Optional: Logging -----
LOG_LEVEL=INFO
