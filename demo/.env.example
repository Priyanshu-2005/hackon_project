# ============================================================
# Demo Frontend - Environment Configuration (Vite)
# ============================================================
# Copy to `.env.local` and adjust for your target backend:
#   cp .env.example .env.local
#
# Vite only exposes variables prefixed with VITE_ to the browser.
# Leave these unset to keep the default local-demo behavior.
# ============================================================

# Local backend (default if unset) -> http://localhost:8080 with /api/v1 prefix.
# For AWS API Gateway, set the full stage URL from the SAM `ApiUrl` output:
#   VITE_API_BASE_URL=https://abc123.execute-api.ap-south-1.amazonaws.com/dev
VITE_API_BASE_URL=

# Path prefix prepended to every request.
#   Local DemoHandler expects /api/v1 (default).
#   API Gateway routes are mounted at the stage root, so set this to empty:
#   VITE_API_PREFIX=
VITE_API_PREFIX=

# Optional Bearer token. Required only when the API Gateway JWT authorizer
# is enabled. Leave empty for the local demo (no auth).
VITE_API_AUTH_TOKEN=
